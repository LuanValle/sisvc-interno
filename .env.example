# Servidor Node/Express
NODE_ENV=production
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=true

# PostgreSQL de desenvolvimento. Substitua somente no arquivo .env local.
DATABASE_URL=postgresql://app_user:change_me@127.0.0.1:5432/app_db
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10

# Acesso administrativo
ADMIN_USER=admin
ADMIN_PASSWORD=change_me
ADMIN_SESSION_SECRET=generate_a_random_secret_with_at_least_32_characters

# Use true quando o proxy publicar a aplicacao com HTTPS.
APP_SECURE_COOKIE=false

# Variaveis de build do frontend. Vazio usa a mesma origem do site.
VITE_API_BASE_URL=
VITE_DEV_API_TARGET=http://127.0.0.1:3000
